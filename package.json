{
  "name": "docuflow-automation",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "install:all": "npm install",
    "prepare": "husky",
    "test": "npm test -w backend && npm test -w frontend && npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "frontend/**/*.{js,jsx,ts,tsx}": [
      "npm run lint -w frontend"
    ]
  },
  "dependencies": {
    "playwright": "^1.61.1",
    "puppeteer": "^25.3.0"
  }
}
