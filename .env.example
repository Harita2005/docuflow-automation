# ==========================================
# DOCUFLOW AUTOMATION - SERVER ENVIRONMENT
# ==========================================

# 1. Database Configuration
# Replace these values with your actual SQL Server details on the company network.
# If your SQL Server is on the same host but outside Docker, use the host IP (e.g. 172.19.64.1)
DATABASE_URL="sqlserver://172.19.64.1:1433;database=DocuFlowDB;user=sa;password=YourSuperStrongPassword123!;trustServerCertificate=true;"

# 2. Security
# Change this to a long, random string in production
JWT_SECRET="your-super-secret-production-jwt-key"

# 3. Application Settings
NODE_ENV="production"
PORT=3000

# 4. Docker Hub Username (Required if using docker-compose.prod.yml)
DOCKER_USERNAME="harita0105"
